[General]
#Path to logfile
logfile = ticketflow.log

[IMAP]
server = imap.example.com
user = username
password = mypassword
#Possible values: tls | ssl | none
encryption = ssl

[SMTP]
server = smtp.example.com
port = 465
#Keep user empty for no authentication
user = username
password = mypassword
sender_mail = openproject@example.com
#Possible values: ssl | none
encryption = ssl

[OpenProject]
base_url = https://openproject.example.com
#https certificate validation (true | false)
https_verification = true
#Input handle like shown when you try to @ mention the bot in the workpackage comments
botuser_handle = IT Support
api_key = mykey1234abc
#Enter values which should be used by new tickets created by mail
#Get the values by looking at https://openproject.example.com/api/v3/work_packages/<id> with id as a ticket configured like ticketflow should do it
ticket_project_id = 3
ticket_type_id = 1
ticket_status_id = 1
ticket_prio_id = 8
#Create a custom field type "Text" where ticketflow can save the sender mail
ticket_usermail_field = customField1
#Ticket closed status id, used to detect if ticket needs to be reopened on comment
ticket_closed_id = 12
#Status-ID to reopen a closed ticket to (see previous), needs permission to do so (workflow in OP)
ticket_reopen_id = 1

[Workflow]
#Convert incoming html mail from this addresses to markdown
mail_html_to_md = [
#    "example@example.com"
    ]
#Should the bot forward OpenProject comments as mail (when mentioned) (true | false)
comment_to_mail = true
#Should the bot return a mail to the sender if a new ticket was created (including the ticket id)? (true | false)
new_ticket_mail_info = true
#Sender-Name for new ticket notification
new_ticket_sendername = "Ticketflow"
#Should the bot send a mail to ticket creator on workpackage status change? (true | false)
status_mail_info = true

[Templates]
#Configure mail templates, use at least one of them, plain or html or both

#Mail template for new ticket alert, available variables:
# $subject Title of the new Workpackage
# $opid ID of the new Workpackage
newticket_subject = $opid Ihr Ticket $subject
newticket_plain = Ihr Ticket mit dem Titel $subject wurde erfasst.
newticket_html = <p>Ihr Ticket mit dem Titel $subject wurde erfasst.</p>
#Mail template for comment mail, available variables:
# $subject Title of the Workpackage
# $opid ID of the Workpackage
# $content Text of the new comment
# $actor Display name of the comment author (OpenProject user)
commentmail_subject = $opid Neue Antwort zu $subject
commentmail_plain = $content
commentmail_html = $content

    <i>Bitte antworten Sie auf diese Nachricht über die Antworten-Funktion des Mailprogramms.
    Wir können Ihre Nachricht dann einfacher zuordnen. Danke!</i>

#Mail template for status change mail, available variables:
# $opid ID of the Workpackage
# $subject Title of the Workpackage
# $statuschange Message from status change activity (Status changed from .. to ..)
statusmail_subject = $opid Status Ihres Servicetickets wurde geändert
statusmail_plain = Der Status Ihres Servicetickets "$subject" wurde geändert:
    $statuschange
statusmail_html = <h3>Der Status Ihres Servicetickets "$subject" wurde geändert:</h3>
    <p>$statuschange</p>